<odoo>
    <template id="report_environmental"><t t-call="web.html_container"><t t-call="web.external_layout"><div class="page"><h2>Environmental Report</h2><table class="table table-sm"><tr><th>Department</th><th>Period</th><th>Environmental Score</th></tr><t t-foreach="docs" t-as="doc"><tr><td><span t-field="doc.department_id"/></td><td><span t-field="doc.period_start"/> – <span t-field="doc.period_end"/></td><td><span t-field="doc.environmental_score"/></td></tr></t></table></div></t></t></template>
    <template id="report_social"><t t-call="web.html_container"><t t-call="web.external_layout"><div class="page"><h2>Social Report</h2><table class="table table-sm"><tr><th>Department</th><th>Period</th><th>Social Score</th></tr><t t-foreach="docs" t-as="doc"><tr><td><span t-field="doc.department_id"/></td><td><span t-field="doc.period_start"/> – <span t-field="doc.period_end"/></td><td><span t-field="doc.social_score"/></td></tr></t></table></div></t></t></template>
    <template id="report_governance"><t t-call="web.html_container"><t t-call="web.external_layout"><div class="page"><h2>Governance Report</h2><table class="table table-sm"><tr><th>Department</th><th>Period</th><th>Governance Score</th></tr><t t-foreach="docs" t-as="doc"><tr><td><span t-field="doc.department_id"/></td><td><span t-field="doc.period_start"/> – <span t-field="doc.period_end"/></td><td><span t-field="doc.governance_score"/></td></tr></t></table></div></t></t></template>
    <template id="report_summary"><t t-call="web.html_container"><t t-call="web.external_layout"><div class="page"><h2>ESG Summary Report</h2><table class="table table-sm"><tr><th>Department</th><th>Environmental</th><th>Social</th><th>Governance</th><th>Total</th></tr><t t-foreach="docs" t-as="doc"><tr><td><span t-field="doc.department_id"/></td><td><span t-field="doc.environmental_score"/></td><td><span t-field="doc.social_score"/></td><td><span t-field="doc.governance_score"/></td><td><span t-field="doc.total_score"/></td></tr></t></table></div></t></t></template>
    <template id="report_custom_esg"><t t-call="web.html_container"><t t-call="web.external_layout"><div class="page"><h2><t t-esc="title"/></h2><table class="table table-sm"><tr><th>Pillar</th><th>Metric</th><th>Value</th></tr><t t-foreach="rows" t-as="row"><tr><td><t t-esc="row['pillar']"/></td><td><t t-esc="row['metric']"/></td><td><t t-esc="row['value']"/></td></tr></t></table></div></t></t></template>
</odoo>
