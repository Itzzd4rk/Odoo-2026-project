<odoo>
    <record id="mail_template_esg_compliance_issue" model="mail.template"><field name="name">ESG: Compliance issue raised</field><field name="model_id" ref="model_esg_compliance_issue"/><field name="email_to">{{ object.owner_id.work_email }}</field><field name="subject">New ESG compliance issue: {{ object.name }}</field><field name="body_html" type="html"><div><p>A new compliance issue has been assigned to you.</p><p><strong>{{ object.name }}</strong> is due on {{ object.due_date }}.</p></div></field></record>
    <record id="mail_template_esg_csr_decision" model="mail.template"><field name="name">ESG: CSR approval decision</field><field name="model_id" ref="model_esg_employee_participation"/><field name="email_to">{{ object.employee_id.work_email }}</field><field name="subject">CSR participation {{ object.approval_status }}</field><field name="body_html" type="html"><div><p>Your CSR participation for {{ object.activity_id.name }} was {{ object.approval_status }}.</p></div></field></record>
    <record id="mail_template_esg_challenge_decision" model="mail.template"><field name="name">ESG: Challenge approval decision</field><field name="model_id" ref="model_esg_challenge_participation"/><field name="email_to">{{ object.employee_id.work_email }}</field><field name="subject">Challenge participation {{ object.approval }}</field><field name="body_html" type="html"><div><p>Your participation in {{ object.challenge_id.title }} was {{ object.approval }}.</p></div></field></record>
    <record id="mail_template_esg_policy_reminder" model="mail.template"><field name="name">ESG: Policy acknowledgement reminder</field><field name="model_id" ref="model_esg_policy_acknowledgement"/><field name="email_to">{{ object.employee_id.work_email }}</field><field name="subject">Policy acknowledgement required: {{ object.policy_id.name }}</field><field name="body_html" type="html"><div><p>Please acknowledge ESG policy <strong>{{ object.policy_id.name }}</strong>.</p></div></field></record>
    <record id="mail_template_esg_badge_unlocked" model="mail.template"><field name="name">ESG: Badge unlocked</field><field name="model_id" ref="model_esg_employee_badge"/><field name="email_to">{{ object.employee_id.work_email }}</field><field name="subject">You unlocked {{ object.badge_id.name }}</field><field name="body_html" type="html"><div><p>Congratulations, you unlocked the ESG badge <strong>{{ object.badge_id.name }}</strong>.</p></div></field></record>
    <record id="mail_template_esg_reward_redemption" model="mail.template"><field name="name">ESG: Reward redemption confirmation</field><field name="model_id" ref="model_esg_reward_redemption"/><field name="email_to">{{ object.employee_id.work_email }}</field><field name="subject">Reward redemption confirmed: {{ object.reward_id.name }}</field><field name="body_html" type="html"><div><p>Your reward redemption has been confirmed.</p></div></field></record>
</odoo>
