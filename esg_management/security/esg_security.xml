<odoo>
    <record id="module_category_esg" model="ir.module.category"><field name="name">ESG</field><field name="sequence">30</field></record>
    <record id="group_esg_user" model="res.groups"><field name="name">ESG User</field><field name="category_id" ref="esg_management.module_category_esg"/></record>
    <record id="group_esg_manager" model="res.groups"><field name="name">ESG Manager</field><field name="category_id" ref="esg_management.module_category_esg"/><field name="implied_ids" eval="[(4, ref('esg_management.group_esg_user'))]"/></record>
    <record id="rule_esg_employee_participation_own" model="ir.rule"><field name="name">ESG participation: own records</field><field name="model_id" ref="model_esg_employee_participation"/><field name="groups" eval="[(4, ref('esg_management.group_esg_user'))]"/><field name="domain_force">[('employee_id.user_id', '=', user.id)]</field><field name="perm_read" eval="True"/><field name="perm_write" eval="True"/><field name="perm_create" eval="True"/><field name="perm_unlink" eval="False"/></record>
    <record id="rule_esg_challenge_participation_own" model="ir.rule"><field name="name">Challenge participation: own records</field><field name="model_id" ref="model_esg_challenge_participation"/><field name="groups" eval="[(4, ref('esg_management.group_esg_user'))]"/><field name="domain_force">[('employee_id.user_id', '=', user.id)]</field><field name="perm_read" eval="True"/><field name="perm_write" eval="True"/><field name="perm_create" eval="True"/><field name="perm_unlink" eval="False"/></record>
    <record id="rule_esg_employee_participation_manager" model="ir.rule"><field name="name">ESG manager participation access</field><field name="model_id" ref="model_esg_employee_participation"/><field name="groups" eval="[(4, ref('esg_management.group_esg_manager'))]"/><field name="domain_force">[(1, '=', 1)]</field></record>
    <record id="rule_esg_challenge_participation_manager" model="ir.rule"><field name="name">ESG manager challenge participation access</field><field name="model_id" ref="model_esg_challenge_participation"/><field name="groups" eval="[(4, ref('esg_management.group_esg_manager'))]"/><field name="domain_force">[(1, '=', 1)]</field></record>
</odoo>
